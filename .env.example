# Copy this file to .env and fill real values.

# Required in production: long random string (sessions, CSRF, signed listing URLs).
SECRET_KEY=replace-with-a-strong-random-secret

# Set FLASK_DEBUG=0 in production. Never enable debug on a public server.
FLASK_DEBUG=0

DATABASE_URL=mssql+pyodbc://username:password@127.0.0.1,60849/NapakWheels?driver=ODBC+Driver+17+for+SQL+Server&TrustServerCertificate=yes

LOG_LEVEL=INFO

UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH_MB=16

# Use SESSION_COOKIE_SECURE=1 when the site is served only over HTTPS.
SESSION_COOKIE_SECURE=0

# SMTP (leave MAIL_SERVER blank to log emails to console instead of sending)
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=no-reply@napak-wheels.local
MAIL_SUPPRESS_SEND=0

# Background jobs.
# Leave broker URL blank to run tasks synchronously inside the request.
# Enable real Celery: install Redis and set:
#   CELERY_BROKER_URL=redis://localhost:6379/0
#   CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_TASK_ALWAYS_EAGER=1

# --- Production deploy (typical) ---
# - Set SECRET_KEY, DATABASE_URL, FLASK_DEBUG=0, SESSION_COOKIE_SECURE=1 (HTTPS).
# - Run DB migrations: flask --app app db upgrade
# - Serve with a WSGI server, e.g. pip install gunicorn
#     gunicorn -w 4 -b 0.0.0.0:8000 "main:app"
#   (Use the same .env / working directory as local; ensure UPLOAD_FOLDER is persistent.)
# - Optional: set CELERY_BROKER_URL for Redis and run a Celery worker for image jobs and emails.
