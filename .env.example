# Copy this file to .env and fill real values.

SECRET_KEY=replace-with-a-strong-random-secret
DATABASE_URL=mssql+pyodbc://username:password@127.0.0.1,60849/NapakWheels?driver=ODBC+Driver+17+for+SQL+Server&TrustServerCertificate=yes

LOG_LEVEL=INFO

UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH_MB=16

SESSION_COOKIE_SECURE=0

# SMTP (leave MAIL_SERVER blank to log emails to console instead of sending)
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=no-reply@napak-wheels.local
MAIL_SUPPRESS_SEND=0

# Background jobs.
# Leave broker URL blank to run tasks synchronously inside the request.
# Enable real Celery: install Redis and set:
#   CELERY_BROKER_URL=redis://localhost:6379/0
#   CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_TASK_ALWAYS_EAGER=1
